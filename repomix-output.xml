name: Update Flake Lock

on:
  schedule:
    - cron: "0 17 * * 0"   # อาทิตย์ 17:00 UTC = จันทร์ 00:00 Bangkok (+7)
  workflow_dispatch:

concurrency:
  group: update-flake-lock
