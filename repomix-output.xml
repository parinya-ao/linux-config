# ==============================================================================

# Strict mode: fail on error, undefined vars, and pipe failures
set -euo pipefail

# --- Global Configurations ---
readonly LOG_FILE="/var/log/firefox_esr_install.log"
CURRENT_STATE="INIT"

# --- ANSI Color Codes ---
C_RED='\033[0;31m'
