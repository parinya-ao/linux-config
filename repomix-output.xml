<file path=".gitlab/ci/update.yaml">
# update.yaml — scheduled flake.lock update
# ตั้งเวลาที่ GitLab: Build > Pipeline schedules
# เพิ่ม variable: UPDATE_FLAKE = "true"

update-flake:
  stage: update
  extends: .nix-setup
  script:
    # อัปเดต lockfile ใน runner ก่อน
    - nix flake update

    # Dry-run build กับ lockfile ใหม่
    # ถ้า fail → จะไม่ push ไม่สร้าง MR → ไม่สร้างขยะ
    - >
      nix build
      .#homeConfigurations.parinya.activationPackage
      --no-link
      --print-build-logs

    # Build ผ่าน → push และสร้าง MR
    - |
      git config user.name  "GitLab Bot"
      git config user.email "bot@noreply.gitlab.com"
      git add flake.lock

      # ถ้า lockfile ไม่ได้เปลี่ยน ก็ออกได้เลย
      if git diff --cached --quiet; then
        echo "[INFO] flake.lock unchanged, nothing to do."
        exit 0
      fi

      git commit -m "chore(nix): update flake.lock [automated]"

      # push ไปยัง branch ใหม่แล้วสร้าง MR อัตโนมัติ
      # (ต้องตั้ง GITLAB_TOKEN ใน CI/CD Variables -> Settings > CI/CD > Variables)
      BRANCH="chore/update-flake-$(date +%Y%m%d)"
      git push \
        "https://bot:${GITLAB_TOKEN}@${CI_SERVER_HOST}/${CI_PROJECT_PATH}.git" \
        "HEAD:refs/heads/${BRANCH}" \
        -o "merge_request.create" \
        -o "merge_request.title=chore(nix): update flake.lock" \
        -o "merge_request.label=dependencies" \
        -o "merge_request.label=automated" \
        -o "merge_request.remove_source_branch"

  rules:
    # รันเฉพาะตอน schedule หรือ manual กด web
    - if: $CI_PIPELINE_SOURCE == "schedule"
    - if: $CI_PIPELINE_SOURCE == "web"
      when: manual
</file>

