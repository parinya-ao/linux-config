<file path=".github/workflows/ci.yaml">
name: Linux Config CI

on:
  push:
    branches: ["main"]
  pull_request:
    branches: ["main"]

concurrency:
  group: ci-${{ github.ref }}
  cancel-in-progress: true

jobs:
  # ─── ด่าน 0: ตรวจว่าไฟล์ไหนเปลี่ยน ─────────────────
  changes:
    name: Detect changed files
    runs-on: ubuntu-latest
    outputs:
      shell: ${{ steps.filter.outputs.shell }}
      nix: ${{ steps.filter.outputs.nix }}
    steps:
      - uses: actions/checkout@v4
      - uses: dorny/paths-filter@v3
        id: filter
        with:
          filters: |
            shell:
              - "**.sh"
              - "distro/**"
              - "steps/**"
              - "lib/**"
              - "startup.sh"
            nix:
              - "**.nix"
              - "flake.lock"

  # ─── ด่าน 1: ShellCheck (Bash/imperative layer) ──────
  shellcheck:
    name: ShellCheck
    needs: changes
    if: ${{ needs.changes.outputs.shell == 'true' }}
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: ludeeus/action-shellcheck@2.0.0
        with:
          scandir: "./"
          severity: warning
          ignore_paths: ".git"

  # ─── ด่าน 2: Nix Lint + Format + Build ──────────────
  nix-build:
    name: Nix Build
    needs: changes
    if: ${{ needs.changes.outputs.nix == 'true' }}
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      # disk space: สำคัญสำหรับ GUI packages หนักๆ ใน home.nix
      - name: Free Disk Space
        uses: jlumbroso/free-disk-space@v1.3.1
        with:
          tool-cache: false
          android: true
          dotnet: true
          haskell: true
          large-packages: true
          docker-images: true
          swap-storage: false   # swap ไว้ก่อน เผื่อ Nix ต้องการ VM

      - name: Install Nix
        uses: cachix/install-nix-action@v30
        with:
          extra_nix_config: |
            experimental-features = nix-command flakes
            accept-flake-config = true

      - name: Setup Magic Nix Cache
        uses: DeterminateSystems/magic-nix-cache-action@v7

      # ── Fail Fast: Lint ก่อน Build (เร็วกว่า build) ──
      - name: Format check (nixfmt)
        # flake formatter = nixfmt-tree (treefmt) which uses --fail-on-change for CI checks
        run: nix fmt -- --fail-on-change

      - name: Lint anti-patterns (statix)
        run: nix run nixpkgs#statix -- check .

      - name: Find dead code (deadnix)
        run: nix run nixpkgs#deadnix -- --fail .

      # ── Fail Fast: evaluate ก่อน build ───────────────
      - name: Flake check (no build)
        run: nix flake check --no-build

      # ── Full Build ────────────────────────────────────
      - name: Build Home Manager Config (parinya)
        run: nix build .#homeConfigurations.parinya.activationPackage --no-link

  # ─── Status gate: PR ต้องผ่านทุก job ────────────────
  # ใช้ required status check ชื่อนี้ใน Branch Protection
  ci-success:
    name: CI passed
    runs-on: ubuntu-latest
    needs: [shellcheck, nix-build]
    if: always()
    steps:
      - name: Evaluate results
        run: |
          shell="${{ needs.shellcheck.result }}"
          nix="${{ needs.nix-build.result }}"

          # ยอมรับ "skipped" (paths-filter ไม่มีไฟล์เปลี่ยน)
          for result in "$shell" "$nix"; do
            if [[ "$result" != "success" && "$result" != "skipped" ]]; then
              echo "::error::Job failed: $result"
              exit 1
            fi
          done
          echo "All required checks passed (shell=$shell, nix=$nix)."
</file>

